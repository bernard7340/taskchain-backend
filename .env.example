# ─────────────────────────────────────────────────────────────────────────────
# TaskChain Backend – Environment Variables
# Copy this file to .env and fill in the values.
# On Railway, set these as environment variables in the service dashboard.
# ─────────────────────────────────────────────────────────────────────────────

# ── Firebase (required) ───────────────────────────────────────────────────────
# Path to your Firebase service-account JSON file.
# On Railway, set FIREBASE_CREDENTIALS_PATH=/app/firebase-credentials.json
# and add the JSON file to your repository (or use a Railway volume).
FIREBASE_CREDENTIALS_PATH=./firebase-credentials.json

# ── Credential encryption (required for cloud multi-user mode) ────────────────
# Fernet symmetric key used to encrypt SmartHQ passwords in memory.
# Generate one with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Keep this secret — it must match across restarts if sessions need to survive.
ENCRYPTION_KEY=

# ── App server ────────────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000

# ── Polling intervals ─────────────────────────────────────────────────────────
POLL_INTERVAL_SMARTHQ=30
POLL_INTERVAL_ROBOROCK=15

# ── CORS origins ──────────────────────────────────────────────────────────────
# Add your Railway app URL after deploying.
# The Android emulator loopback (10.0.2.2) is included for local dev.
CORS_ORIGINS=["https://your-app.railway.app","http://10.0.2.2:8000","http://localhost:8000"]

# ─────────────────────────────────────────────────────────────────────────────
# Legacy single-user mode (optional — leave blank to use cloud multi-user mode)
# These are only used if you want a single hardcoded SmartHQ account instead
# of per-user credentials entered in the app.
# ─────────────────────────────────────────────────────────────────────────────
SMARTHQ_API_KEY=
SMARTHQ_USERNAME=
SMARTHQ_PASSWORD=
ROBOROCK_USERNAME=
ROBOROCK_PASSWORD=
FCM_DEFAULT_TOKEN=
